# DeepWorld — API Keys (copy to .env and fill in your keys)
# .env is gitignored — never commit real keys

# DeepSeek API (paid, fast ~1s/call)
# Get from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-key-here

# Nvidia NIM API (free tier, ~3-60s/call)
# Get from: https://build.nvidia.com/explore/discover
# Model: nvidia/llama-3.1-nemotron-nano-8b-v1
NVIDIA_API_KEY=nvapi-your-key-here

# Optional: Gemini Web (free, requires browser login)
# Run `gemini-cli -l` once to authenticate
# No API key needed — uses browser cookies

# Optional: Claude Web (free, requires browser login)  
# Run `python3 claude.py --save-all` once to authenticate
# No API key needed — uses browser cookies
